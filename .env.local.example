# Supabase 接続情報。.env.local にコピーして値を設定してください。
#
# ローカル開発（supabase start）の場合、`supabase start` の出力に表示される
#   API URL  → NEXT_PUBLIC_SUPABASE_URL
#   anon key → NEXT_PUBLIC_SUPABASE_ANON_KEY
# をそのまま貼り付けます（例: http://127.0.0.1:54321）。
#
# クラウドの場合は Supabase ダッシュボード → Project Settings → API から取得します。

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# サイトのベースURL（パスワード再設定メールのリンク先・OAuthリダイレクトに使用）
# ローカル: http://localhost:3000 / 本番: https://あなたのドメイン
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ===== Stripe（サブスク決済）=====
# Stripeダッシュボードから取得。すべてサーバー専用（NEXT_PUBLIC は付けない）。
STRIPE_SECRET_KEY=
# 月額499円の定期課金 Price の ID（price_xxx）
STRIPE_PRICE_ID=
# Webhookエンドポイントの署名シークレット（whsec_xxx）
STRIPE_WEBHOOK_SECRET=
# Webhookが課金状態を書き込むためのサービスロールキー（Supabase Settings→API）
# 絶対に公開しないこと。サーバー専用。
SUPABASE_SERVICE_ROLE_KEY=

# ===== 表示広告（任意・無料ユーザーに表示）=====
# 広告ネットワークの広告タグHTMLをそのまま貼る（A8.netバナー / 忍者AdMax 等）。
# 未設定の間はプレースホルダー表示。設定するとサイトに広告が出ます。
# 例(A8バナー): <a href="https://px.a8.net/..."><img ... border="0"></a><img ... 1x1 ...>
NEXT_PUBLIC_AD_HTML=
# 広告枠の幅・高さ(px)。バナー種別に合わせて調整（既定 300x250）。
# 例: 300x250→W300/H250、728x90→W728/H90、320x100→W320/H100
NEXT_PUBLIC_AD_WIDTH=300
NEXT_PUBLIC_AD_HEIGHT=250

# Google Search Console のHTMLタグ確認トークン（content="..." の値）
GOOGLE_SITE_VERIFICATION=
