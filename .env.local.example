# Supabase 接続情報。.env.local にコピーして値を設定してください。
#
# ローカル開発（supabase start）の場合、`supabase start` の出力に表示される
#   API URL  → NEXT_PUBLIC_SUPABASE_URL
#   anon key → NEXT_PUBLIC_SUPABASE_ANON_KEY
# をそのまま貼り付けます（例: http://127.0.0.1:54321）。
#
# クラウドの場合は Supabase ダッシュボード → Project Settings → API から取得します。

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# サイトのベースURL（パスワード再設定メールのリンク先・OAuthリダイレクトに使用）
# ローカル: http://localhost:3000 / 本番: https://あなたのドメイン
NEXT_PUBLIC_SITE_URL=http://localhost:3000
